  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Survive waves of enemies and defeat the Mothership. To make the Mothership
    vulnerable you must kill a required number of support enemies shown on the HUD.
    When the counter reaches the target the HUD will display that the Mothership
    is vulnerable\u2014then focus the boss.\r\n\nPC Controls\r\n\u2022\tMovement:
    W / A / S / D\r\n\u2022\tAim: mouse (player points toward cursor)\r\n\u2022\tFire:
    left mouse button (hold for continuous fire if available)\r\n\u2022\tDrop Bomb:
    right mouse button (use strategically)\r\n\u2022\tPause / Menu: Esc\r\n\nMobile
    Controls\r\n\u2022\tMovement: left virtual joystick\r\n\u2022\tAim & Fire: right
    virtual joystick (dual-stick) or on-screen fire button\r\n\u2022\tBomb: on-screen
    bomb button\r\n\u2022\tPause: on-screen pause button\r\n\nCore Mechanics\r\n\u2022\tHealth
    & Lives: your health is shown on the HUD; collect health power-ups to recover
    lives.\r\n\u2022\tInvincibility: after taking damage you get a short invincibility
    period with a visual flicker.\r\n\u2022\tPower-ups: Shield (temporary protection),
    Health (restore lives), Weapon (upgrade shots), Bomb (screen-clear).\r\n\u2022\tDeath
    effects: enemies trigger a death effect when destroyed; avoid destroying enemies
    in a way that prevents that effect from playing (e.g., instant removal).\r\n\nMothership
    & Shield\r\n\u2022\tThe HUD shows enemies killed / required. Reach the required
    number to break the shield.\r\n\u2022\tAfter the shield falls, attack the Mothership
    directly to reduce its health.\r\nStrategy Tips\r\n\u2022\tPrioritize clearing
    support enemies to open the boss shield faster.\r\n\u2022\tSave bombs for tight
    situations or big enemy clusters.\r\n\u2022\tKeep moving and use ranged attacks;
    collisions damage both you and enemies.\r\n\u2022\tPick up weapon upgrades before
    heavy boss fights."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
  m_sharedMaterial: {fileID: 2164040, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
